{
  "expo": {
    "name": "AgentOS Mobile",
    "slug": "agentos-mobile",
    "version": "7.2.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "agentos",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.agentos.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0f172a"
      },
      "package": "com.agentos.mobile"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-asset",
      [
        "expo-build-properties",
        {
          "android": {
            "usesCleartextTraffic": true
          }
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow AgentOS to access your photos for attachment uploads.",
          "cameraPermission": "Allow AgentOS to take photos for attachment uploads."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "b6900fa8-496a-414c-a929-c9be1b319f57"
      }
    },
    "owner": "hitechtn-org"
  }
}
