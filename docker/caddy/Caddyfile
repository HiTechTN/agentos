# Caddy reverse proxy for AgentOS
:80 {
    handle /api/* {
        reverse_proxy app:8000
    }
    handle /health {
        reverse_proxy app:8000
    }
    handle /metrics {
        reverse_proxy app:8000
    }
    handle /ws/* {
        reverse_proxy app:8000
    }
    handle {
        reverse_proxy web:3000
    }
}
