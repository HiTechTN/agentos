LOG_LEVEL=INFO
PROJECT_ID=demo-project
ENVIRONMENT=development

OPENROUTER_API_KEY=sk-demo-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

DEV_AGENT_MODEL=anthropic/claude-sonnet-20241022
CONTENT_AGENT_MODEL=openai/gpt-4o-2024-11-20
MARKETING_AGENT_MODEL=anthropic/claude-sonnet-20241022
COMMERCE_AGENT_MODEL=openai/gpt-4o-2024-11-20

MODEL_FOR_CODE=anthropic/claude-sonnet-20241022
MODEL_FOR_CONTENT=openai/gpt-4o-2024-11-20
MODEL_FOR_ANALYSIS=mistralai/mixtral-8x22b-instruct
MODEL_FOR_COMMERCE=openai/gpt-4o-2024-11-20
MODEL_FOR_DEFAULT=openai/gpt-4o-2024-11-20

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_FALLBACK_MODEL=qwen2.5

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agentos
POSTGRES_USER=agentos
POSTGRES_PASSWORD=agentos_demo_password
DATABASE_URL=postgresql+asyncpg://agentos:agentos_demo_password@localhost:5432/agentos

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0

OPENAI_API_KEY=sk-demo-openai-key
ANTHROPIC_API_KEY=sk-demo-anthropic-key

JWT_SECRET=demo-jwt-secret-for-recording-only
JWT_ALGORITHM=HS256
HITL_ENABLED=true
SESSION_TIMEOUT_MINUTES=60

ENABLE_LLM_CACHE=true
LLM_CACHE_TTL=3600

ENABLE_TELEMETRY=false
OTEL_SERVICE_NAME=agentos-demo
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

SLACK_WEBHOOK_URL=

WORKSPACE_DIR=/tmp/agentos_workspaces
MAX_CONCURRENT_TASKS=4
