# =============================================================================
# AgentOS v5.0 - Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- General ---
LOG_LEVEL=INFO
PROJECT_ID=demo-project
ENVIRONMENT=development

# --- LLM - OpenRouter (primary) ---
OPENROUTER_API_KEY=sk-demo-openrouter-key-replace-me
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Agent models (overridable per agent) ---
DEV_AGENT_MODEL=anthropic/claude-sonnet-20241022
CONTENT_AGENT_MODEL=openai/gpt-4o-2024-11-20
MARKETING_AGENT_MODEL=anthropic/claude-sonnet-20241022
COMMERCE_AGENT_MODEL=openai/gpt-4o-2024-11-20

# --- Multi-model routing (per task type) ---
MODEL_FOR_CODE=anthropic/claude-sonnet-20241022
MODEL_FOR_CONTENT=openai/gpt-4o-2024-11-20
MODEL_FOR_ANALYSIS=mistralai/mixtral-8x22b-instruct
MODEL_FOR_COMMERCE=openai/gpt-4o-2024-11-20
MODEL_FOR_DEFAULT=openai/gpt-4o-2024-11-20

# --- LLM - Ollama (fallback) ---
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_FALLBACK_MODEL=qwen2.5

# --- Embedding ---
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=768
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Database ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=agentos
POSTGRES_USER=agentos
POSTGRES_PASSWORD=agentos_demo_password
DATABASE_URL=postgresql+asyncpg://agentos:agentos_demo_password@postgres:5432/agentos

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=agentos_redis_demo
REDIS_URL=redis://:agentos_redis_demo@redis:6379/0

# --- JWT Authentication ---
JWT_SECRET=agentos-jwt-secret-change-in-prod
JWT_ALGORITHM=HS256
JWT_EXPIRY_HOURS=24

# --- Rate Limiting ---
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_RUN=10/minute
RATE_LIMIT_PLAN=20/minute
RATE_LIMIT_VERIFY=30/minute

# --- Session Secret (NextAuth) ---
NEXTAUTH_SECRET=agentos-nextauth-secret-change-in-prod
NEXTAUTH_URL=http://localhost:3000

# --- OAuth2 Providers ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- Stripe (CommerceAgent) ---
STRIPE_API_KEY=sk_test_demo_placeholder
STRIPE_WEBHOOK_SECRET=whsec_demo_placeholder
STRIPE_PRICE_ID=price_demo_placeholder

# --- GitHub (DevAgent) ---
GITHUB_TOKEN=ghp_demo_token_replace_me

# --- Replicate (ContentAgent - Image Gen) ---
REPLICATE_API_TOKEN=r8_demo_token_replace_me

# --- Sandbox ---
SANDBOX_ENABLED=true
SANDBOX_NETWORK=agentos_net

# --- HITL ---
HITL_MODE=webhook_and_cli
HITL_TIMEOUT=0

# --- OpenTelemetry / Tracing ---
OTLP_ENDPOINT=http://jaeger:4318
OTLP_ENABLED=false
SERVICE_NAME=agentos

# --- S3 / MinIO ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=agentos
S3_SECRET_KEY=agentos_minio_demo
S3_BUCKET=agentos

# --- Notifications ---
SLACK_WEBHOOK_URL=
NOTIFICATION_EMAIL_FROM=agentos@localhost
NOTIFICATION_SMTP_HOST=mailhog
NOTIFICATION_SMTP_PORT=1025

# --- Scheduler ---
SCHEDULER_ENABLED=true
SCHEDULER_CHECK_INTERVAL=60

# --- Strapi ---
STRAPI_JWT_SECRET=strapi-demo-jwt-secret
STRAPI_ADMIN_JWT_SECRET=strapi-admin-jwt-secret

# --- OpenAI (embeddings only) ---
OPENAI_API_KEY=sk-your-openai-key-here
